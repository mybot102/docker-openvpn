# 注意：此镜像的所有变量均为可选项。
# 详情参见 README。
# 使用时请取消注释并替换为你自己的值。

# 使用 DNS 名称作为 VPN 服务器地址
# - DNS 名称必须是完全限定域名 (FQDN)
# - 未设置时将自动检测服务器公网 IP 地址
# VPN_DNS_NAME=vpn.example.com

# 使用 VPN 服务器的公网 IP 地址
# - 仅在未设置 VPN_DNS_NAME 且自动检测失败时需要
# VPN_PUBLIC_IP=your_server_ip

# OpenVPN 协议（tcp 或 udp，默认：tcp）
# VPN_PROTO=tcp

# OpenVPN 端口（1-65535，默认：1194）
# VPN_PORT=1194

# 指定第一个 VPN 客户端的名称
# - 只使用一个单词，除 '-' 和 '_' 外不含特殊字符
# - 未指定时默认为 'client'
# VPN_CLIENT_NAME=your_client_name

# 为 VPN 客户端使用其他 DNS 服务器
# - 默认使用 Google 公共 DNS（8.8.8.8 和 8.8.4.4）
# - 以下示例使用 Cloudflare DNS 服务
# VPN_DNS_SRV1=1.1.1.1
# VPN_DNS_SRV2=1.0.0.1

# 覆盖自动检测到的服务器 IPv6 地址
# - IPv6 地址会自动检测，仅在自动检测失败时设置此项
# - 设置为有效的 IPv6 地址时，将启用 IPv6 支持
# VPN_PUBLIC_IP6=your_server_ipv6